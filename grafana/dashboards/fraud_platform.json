{
  "__inputs": [
    {
      "name": "DS_POSTGRES",
      "label": "PostgreSQL",
      "type": "datasource",
      "pluginId": "postgres"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "postgres",
      "name": "PostgreSQL",
      "version": "1.0.0"
    }
  ],
  "title": "Fraud Platform",
  "tags": [
    "fraud",
    "mlops"
  ],
  "schemaVersion": 36,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Predictions",
      "datasource": {
        "uid": "fraud-postgres",
        "type": "postgres"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "fraud-postgres",
            "type": "postgres"
          },
          "rawSql": "SELECT COUNT(*) AS total FROM predictions",
          "rawQuery": true,
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Requests (last 24 h)",
      "datasource": {
        "uid": "fraud-postgres",
        "type": "postgres"
      },
      "gridPos": {
        "x": 5,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "fraud-postgres",
            "type": "postgres"
          },
          "rawSql": "SELECT COUNT(*) AS requests FROM predictions WHERE created_at > NOW() - INTERVAL '24 hours'",
          "rawQuery": true,
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg Latency (ms)",
      "datasource": {
        "uid": "fraud-postgres",
        "type": "postgres"
      },
      "gridPos": {
        "x": 10,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "fraud-postgres",
            "type": "postgres"
          },
          "rawSql": "SELECT ROUND(AVG(latency_ms)::numeric,1) AS avg_ms FROM predictions WHERE created_at > NOW() - INTERVAL '24 hours'",
          "rawQuery": true,
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Drift Events (24 h)",
      "datasource": {
        "uid": "fraud-postgres",
        "type": "postgres"
      },
      "gridPos": {
        "x": 15,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "fraud-postgres",
            "type": "postgres"
          },
          "rawSql": "SELECT COUNT(*) AS events FROM drift_events WHERE checked_at > NOW() - INTERVAL '24 hours'",
          "rawQuery": true,
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latency p50/p95/p99 (ms)",
      "datasource": {
        "uid": "fraud-postgres",
        "type": "postgres"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 16,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "fraud-postgres",
            "type": "postgres"
          },
          "rawSql": "SELECT date_trunc('minute', created_at) AS time, ROUND(percentile_cont(0.50) WITHIN GROUP (ORDER BY latency_ms)::numeric,1) AS p50, ROUND(percentile_cont(0.95) WITHIN GROUP (ORDER BY latency_ms)::numeric,1) AS p95, ROUND(percentile_cont(0.99) WITHIN GROUP (ORDER BY latency_ms)::numeric,1) AS p99 FROM predictions WHERE created_at > NOW() - INTERVAL '24 hours' GROUP BY 1 ORDER BY 1",
          "rawQuery": true,
          "format": "time_series",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Fraud Score Distribution",
      "datasource": {
        "uid": "fraud-postgres",
        "type": "postgres"
      },
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "fraud-postgres",
            "type": "postgres"
          },
          "rawSql": "SELECT ROUND((width_bucket(fraud_score,0,1,10)-1)::numeric/10,1)::text AS bucket, COUNT(*) AS cnt FROM predictions WHERE created_at > NOW() - INTERVAL '24 hours' AND fraud_score IS NOT NULL GROUP BY 1 ORDER BY 1",
          "rawQuery": true,
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Feature PSI \u2014 Latest Drift Check",
      "datasource": {
        "uid": "fraud-postgres",
        "type": "postgres"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "fraud-postgres",
            "type": "postgres"
          },
          "rawSql": "SELECT kv.key AS feature, ROUND(kv.value::numeric,4) AS psi, CASE WHEN kv.value::float>0.2 THEN 'DRIFT' ELSE 'OK' END AS status FROM drift_events de, json_each_text(de.feature_psi::json) kv WHERE de.checked_at=(SELECT MAX(checked_at) FROM drift_events) ORDER BY psi DESC",
          "rawQuery": true,
          "format": "table",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Drift History \u2014 KL Divergence",
      "datasource": {
        "uid": "fraud-postgres",
        "type": "postgres"
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "fraud-postgres",
            "type": "postgres"
          },
          "rawSql": "SELECT checked_at AS time, score_kl AS kl_divergence FROM drift_events WHERE checked_at > NOW() - INTERVAL '24 hours' ORDER BY checked_at",
          "rawQuery": true,
          "format": "time_series",
          "editorMode": "code"
        }
      ]
    }
  ]
}
